{
  "name": "cargohub",
  "version": "1.0.0",
  "private": true,
  "description": "CargoHub — Cross-platform cargo logistics platform",
  "workspaces": [
    "frontend/*",
    "backend",
    "backend/src/shared",
    "mobile-app/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:customer\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:customer": "npm run dev --workspace=frontend/customer-portal",
    "dev:mobile": "npm run start --workspace=cargohub-app",
    "dev:mobile:android": "npm run android --workspace=cargohub-app",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "@types/react": "^18.2.79",
    "concurrently": "^9.1.2",
    "expo": "~52.0.49",
    "expo-asset": "~11.0.5",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "react-native": "0.76.9",
    "expo": "~52.0.49",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@types/react": "18.2.79"
  },
  "dependencies": {
    "expo-task-manager": "^12.0.6"
  }
}
